{
  "$schema": "https://mintlify.com/docs.json",
  "name": "chifu",
  "theme": "maple",
  "logo": {
    "light": "/images/fish-logo.png",
    "dark": "/images/fish-logo.png",
    "href": "https://marshell.dev"
  },
  "favicon": "/images/fish-logo.png",
  "colors": {
    "primary": "#0A0A0A",
    "light": "#F5F5F5",
    "dark": "#171717"
  },
  "appearance": {
    "default": "dark"
  },
  "background": {
    "color": {
      "dark": "#0A0A0A",
      "light": "#FFFFFF"
    }
  },
  "fonts": {
    "family": "Inter"
  },
  "icons": {
    "library": "lucide"
  },
  "styling": {
    "css": ["/style.css"]
  },
  "navbar": {
    "links": [
      {
        "label": "Dashboard",
        "href": "https://marshell.dev/dashboard"
      },
      {
        "label": "Pricing",
        "href": "https://marshell.dev/plans"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Install",
      "href": "https://marshell.dev"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/marshell-dev",
      "discord": "https://discord.gg/pPsKMze28n"
    }
  },
  "navigation": {
    "groups": [
      {
        "group": "Start",
        "pages": ["index", "quickstart", "how-it-works"]
      },
      {
        "group": "Use chifu",
        "pages": ["capabilities", "cli", "ecosystems", "ci"]
      },
      {
        "group": "Agents",
        "pages": ["skill", "agents"]
      },
      {
        "group": "Account",
        "pages": ["dashboard", "plans", "troubleshooting"]
      }
    ]
  }
}
